# Database
DATABASE_URL="file:./dev.db"

# Auth
SESSION_SECRET="change-me-to-a-random-string"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# Square (alternative processor — coaches pick Stripe OR Square)
# SQUARE_ENVIRONMENT: "sandbox" (default) or "production".
# Register the OAuth redirect URL http://localhost:8787/api/coach-payments/square/callback
# and the webhook URL http://<public-tunnel>/api/webhooks/square in the Square dashboard.
SQUARE_ENVIRONMENT="sandbox"
SQUARE_APPLICATION_ID=""
SQUARE_APPLICATION_SECRET=""
SQUARE_WEBHOOK_SIGNATURE_KEY=""

# Email — Cloudflare Email Sending binding (env.EMAIL, configured in
# apps/api/wrangler.toml as [[send_email]]). No API key; the EMAIL_FROM domain
# must be onboarded once via `npx wrangler email sending enable usesunbird.com`.
EMAIL_FROM="Ellisa Sun <hello@usesunbird.com>"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="ellisa-songs"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8787/api/auth/oauth/google/cb"
