generator client {
  provider = "prisma-client-js"
}

generator worker {
  provider = "prisma-client"
  output   = "../../../apps/api/src/generated/prisma"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String?
  avatarUrl      String?
  bio            String?
  role           String   @default("STUDENT")
  slug           String?  @unique
  headline       String?
  longBio        String?
  coverImageUrl  String?
  credentials    String?
  socialLinks    String?
  isPublished    Boolean  @default(false)
  sessionAddress String?
  referralSource String?
  age            Int?
  instrument     String?
  lastInboxViewedAt DateTime?

  // Current routine — JSON-stringified RoutineItem[] (see shared/types.ts).
  // Coach-managed; rendered on the student's Practice path and the
  // coach's Plan/Next tabs. Stored as JSON to avoid a separate table.
  currentRoutine String?

  // Stripe Connect (Express) — set once the coach starts the
  // onboarding flow. Flags mirror Stripe's account.{charges,payouts,
  // details_submitted} so the dashboard can render the right stage
  // without an API roundtrip on every page load.
  stripeAccountId        String?
  stripeChargesEnabled   Boolean @default(false)
  stripePayoutsEnabled   Boolean @default(false)
  stripeDetailsSubmitted Boolean @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions        Session[]
  oauthAccounts   OAuthAccount[]
  subscription    Subscription?
  bookings        Booking[]
  songs           Song[]
  songLikes       SongLike[]
  songComments    SongComment[]
  eventRsvps      EventRsvp[]
  contactMessages    ContactMessage[]
  passwordResetTokens PasswordResetToken[]
  coachBookings      Booking[]           @relation("coachBookings")
  sentMessages       SessionMessage[]
  addedResources     SessionResource[]
  coachAvailability  CoachAvailability[]
  coachBusy          CoachBusy[]
  coachLessonTypes   CoachLessonType[]
  coachPaths         Path[]              @relation("coachPaths")
  studentPathAssignments PathAssignment[] @relation("studentPathAssignments")
  coachPathAssignments   PathAssignment[] @relation("coachPathAssignments")
  libraryItems       LibraryItem[]       @relation("coachLibraryItems")
  messageReads       SessionMessageRead[]
  googleEvents       GoogleEvent[]
  recurringSchedules RecurringSchedule[] @relation("studentSchedules")
  coachSchedules     RecurringSchedule[] @relation("coachSchedules")
  coachResources     CoachResource[]     @relation("coachResources")
  coachCurricula     Curriculum[]        @relation("coachCurricula")
  coachCategories    CoachCategory[]
  coachSkillTrees    SkillTree[]         @relation("coachSkillTrees")
  stStudentProgress  STNodeProgress[]    @relation("stStudentProgress")
  stCoachProgress    STNodeProgress[]    @relation("stCoachProgress")
  studentProgress    StudentProgress[]   @relation("studentProgress")
  coachProgressMarks StudentProgress[]   @relation("coachProgress")

  // Practice / coach UI additions
  practiceStreak        PracticeStreak?
  studentAssignments    Assignment[]        @relation("studentAssignments")
  coachAssignments      Assignment[]        @relation("coachAssignments")
  studentTakes          Take[]              @relation("studentTakes")
  coachTakes            Take[]              @relation("coachTakes")
  takeAnnotations       TakeAnnotation[]
  takeReplies           TakeReply[]
  noteReadReceipts      NoteReadReceipt[]
  noteVoiceMemos        NoteVoiceMemo[]
  lessonSummariesEdited LessonSummary[]     @relation("summaryEditor")
  routineCompletions    RoutineCompletion[]
  studentGoals          Goal[]              @relation("studentGoals")
  coachGoals            Goal[]              @relation("coachGoals")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id                   String    @id @default(cuid())
  provider             String
  providerId           String
  userId               String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  scopes               String?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Lessons & Scheduling ───

model LessonType {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  subtitle        String?
  description     String
  imageUrl        String?
  pricePerSession Int
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  categories      LessonCategory[]
  bookings        Booking[]
  workshops       Workshop[]
  coachLessonTypes CoachLessonType[]
  curricula        Curriculum[]
}

model LessonCategory {
  id           String  @id @default(cuid())
  lessonTypeId String
  slug         String
  title        String
  description  String?
  sortOrder    Int     @default(0)

  lessonType LessonType @relation(fields: [lessonTypeId], references: [id])
  bookings   Booking[]

  @@unique([lessonTypeId, slug])
}

model AvailabilitySlot {
  id        String  @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
}

model CoachAvailability {
  id        String  @id @default(cuid())
  coachId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)

  coach User @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([coachId, dayOfWeek, startTime])
}

// Items in a coach's Library — warmups, exercises, and songs they can
// drag onto a student's week or attach to path lessons. Lightweight
// metadata (bpm range, duration, MIDI/PDF/audio refs); tags are stored
// as a JSON string for simplicity.
model LibraryItem {
  id          String   @id @default(cuid())
  coachId     String
  kind        String   // "warmup" | "exercise" | "song"
  title       String
  subtitle    String?
  tags        String   @default("[]") // JSON array of strings
  bpmStart    Int?
  bpmEnd      Int?
  durationMin Int?
  hasMidi     Boolean  @default(false)
  midiUrl     String?
  pdfUrl      String?
  audioUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach User @relation("coachLibraryItems", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
}

// Khan-style lesson tree owned by a coach. The graph (nodes + edges) is
// stored as JSON on the row — small (typically <30 nodes), keeps schema
// churn down, and matches how noteSections is handled elsewhere.
model Path {
  id        String   @id @default(cuid())
  coachId   String
  slug      String
  title     String
  sub       String?
  shape     String   @default("linear") // "linear" | "branch" | "spiral"
  status    String   @default("draft")  // "draft" | "published"
  coral     Boolean  @default(false)
  nodes     String   @default("[]")     // JSON array of PathLessonNode
  edges     String   @default("[]")     // JSON array of [fromId, toId]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach       User             @relation("coachPaths", fields: [coachId], references: [id], onDelete: Cascade)
  assignments PathAssignment[]

  @@unique([coachId, slug])
}

// A student walking through one of a coach's paths.
model PathAssignment {
  id              String   @id @default(cuid())
  pathId          String
  studentId       String
  coachId         String
  currentLessonId String?
  startedAt       DateTime @default(now())

  path    Path @relation(fields: [pathId], references: [id], onDelete: Cascade)
  student User @relation("studentPathAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  coach   User @relation("coachPathAssignments", fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([pathId, studentId])
  @@index([coachId])
  @@index([studentId])
}

// Two-way Google Calendar sync mirror/shadow row.
//
//   - "Outbound mirror" — bookingId or busyId is set; we created this
//     event on Google to reflect a Sunbird resource. Used to update
//     or delete the Google event later.
//   - "Inbound shadow" — both bookingId and busyId are null; this row
//     was pulled from Google so the coach's existing calendar entries
//     block them from being double-booked on Sunbird.
model GoogleEvent {
  id               String   @id @default(cuid())
  coachId          String
  googleEventId    String
  googleCalendarId String   @default("primary")
  bookingId        String?
  busyId           String?
  startsAt         DateTime
  endsAt           DateTime
  summary          String?
  syncedAt         DateTime @default(now())

  coach   User       @relation(fields: [coachId], references: [id], onDelete: Cascade)
  booking Booking?   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  busy    CoachBusy? @relation(fields: [busyId],    references: [id], onDelete: SetNull)

  @@unique([coachId, googleEventId])
  @@index([coachId])
  @@index([bookingId])
  @@index([busyId])
}

// Date-specific busy block. Takes precedence over CoachAvailability when
// computing bookable slots — if any CoachBusy row overlaps the requested
// time range for this coach, the slot is unavailable regardless of the
// recurring weekly availability.
model CoachBusy {
  id        String   @id @default(cuid())
  coachId   String
  startsAt  DateTime
  endsAt    DateTime
  label     String?
  createdAt DateTime @default(now())

  coach        User          @relation(fields: [coachId], references: [id], onDelete: Cascade)
  googleEvents GoogleEvent[]

  @@index([coachId, startsAt])
}

model CoachLessonType {
  id           String @id @default(cuid())
  coachId      String
  lessonTypeId String

  coach      User       @relation(fields: [coachId], references: [id], onDelete: Cascade)
  lessonType LessonType @relation(fields: [lessonTypeId], references: [id], onDelete: Cascade)

  @@unique([coachId, lessonTypeId])
}

// ─── Curriculum / Skill Trees ───

model Curriculum {
  id           String   @id @default(cuid())
  coachId      String
  lessonTypeId String
  title        String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coach      User             @relation("coachCurricula", fields: [coachId], references: [id], onDelete: Cascade)
  lessonType LessonType       @relation(fields: [lessonTypeId], references: [id], onDelete: Cascade)
  nodes      CurriculumNode[]
  edges      CurriculumEdge[]

  @@unique([coachId, lessonTypeId])
}

model CurriculumNode {
  id           String  @id @default(cuid())
  curriculumId String
  title        String
  description  String?
  positionX    Float   @default(0)
  positionY    Float   @default(0)
  color        String?
  sortOrder    Int     @default(0)

  curriculum Curriculum        @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  edgesFrom  CurriculumEdge[]  @relation("edgeFrom")
  edgesTo    CurriculumEdge[]  @relation("edgeTo")
  progress   StudentProgress[]
  resourceLinks NodeResourceLink[]
  drills        PracticeDrill[]
}

model CoachResource {
  id        String   @id @default(cuid())
  coachId   String
  type      String
  title     String
  url       String
  createdAt DateTime @default(now())

  coach     User               @relation("coachResources", fields: [coachId], references: [id], onDelete: Cascade)
  nodeLinks       NodeResourceLink[]
  stResourceLinks STNodeResourceLink[] @relation("stResourceLinks")
  assignments     Assignment[]
}

model NodeResourceLink {
  id         String @id @default(cuid())
  nodeId     String
  resourceId String

  node     CurriculumNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  resource CoachResource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([nodeId, resourceId])
}

model PracticeDrill {
  id          String  @id @default(cuid())
  nodeId      String
  title       String
  description String?
  resourceId  String?
  sortOrder   Int     @default(0)

  node CurriculumNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model CurriculumEdge {
  id           String @id @default(cuid())
  curriculumId String
  fromNodeId   String
  toNodeId     String

  curriculum Curriculum     @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  fromNode   CurriculumNode @relation("edgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     CurriculumNode @relation("edgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
}

model StudentProgress {
  id          String   @id @default(cuid())
  studentId   String
  nodeId      String
  coachId     String
  completedAt DateTime @default(now())
  notes       String?

  student User           @relation("studentProgress", fields: [studentId], references: [id], onDelete: Cascade)
  node    CurriculumNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  coach   User           @relation("coachProgress", fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([studentId, nodeId])
}

// ─── Categories & Skill Trees (New Hierarchy) ───

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  coachCategories    CoachCategory[]
  skillTrees         SkillTree[]
  bookings           Booking[]           @relation("bookingCategory")
  recurringSchedules RecurringSchedule[] @relation("scheduleCategory")
}

model CoachCategory {
  id         String @id @default(cuid())
  coachId    String
  categoryId String

  coach    User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([coachId, categoryId])
}

model SkillTree {
  id          String   @id @default(cuid())
  coachId     String
  categoryId  String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach              User                @relation("coachSkillTrees", fields: [coachId], references: [id], onDelete: Cascade)
  category           Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nodes              SkillTreeNode[]
  edges              SkillTreeEdge[]
  bookings           Booking[]           @relation("bookingSkillTree")
  recurringSchedules RecurringSchedule[] @relation("scheduleSkillTree")
}

model SkillTreeNode {
  id          String  @id @default(cuid())
  skillTreeId String
  title       String
  description String?
  positionX   Float   @default(0)
  positionY   Float   @default(0)
  color       String?
  sortOrder   Int     @default(0)

  skillTree     SkillTree          @relation(fields: [skillTreeId], references: [id], onDelete: Cascade)
  edgesFrom     SkillTreeEdge[]    @relation("stEdgeFrom")
  edgesTo       SkillTreeEdge[]    @relation("stEdgeTo")
  progress      STNodeProgress[]
  resourceLinks STNodeResourceLink[]
  drills        STDrill[]
  bookings      Booking[]           @relation("bookingNode")
  recurringSchedules RecurringSchedule[] @relation("scheduleNode")
}

model SkillTreeEdge {
  id          String @id @default(cuid())
  skillTreeId String
  fromNodeId  String
  toNodeId    String

  skillTree SkillTree     @relation(fields: [skillTreeId], references: [id], onDelete: Cascade)
  fromNode  SkillTreeNode @relation("stEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode    SkillTreeNode @relation("stEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
}

model STNodeProgress {
  id          String   @id @default(cuid())
  studentId   String
  nodeId      String
  coachId     String
  completedAt DateTime @default(now())
  notes       String?

  student User          @relation("stStudentProgress", fields: [studentId], references: [id], onDelete: Cascade)
  node    SkillTreeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  coach   User          @relation("stCoachProgress", fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([studentId, nodeId])
}

model STNodeResourceLink {
  id         String @id @default(cuid())
  nodeId     String
  resourceId String

  node     SkillTreeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  resource CoachResource @relation("stResourceLinks", fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([nodeId, resourceId])
}

model STDrill {
  id          String  @id @default(cuid())
  nodeId      String
  title       String
  description String?
  resourceId  String?
  sortOrder   Int     @default(0)

  node SkillTreeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model Booking {
  id                  String    @id @default(cuid())
  userId              String
  coachId             String?
  lessonTypeId        String?
  lessonCategoryId    String?
  startsAt            DateTime
  endsAt              DateTime
  status              String    @default("CONFIRMED")
  mode                String    @default("IN_PERSON")
  meetingUrl          String?
  meetingId           String?
  meetingProvider     String?
  callSessionId       String?
  studentNote         String?
  practiceNotes       String?
  practiceNotesSentAt DateTime?
  completedAt         DateTime?
  stripePaymentId     String?
  usedSubscription    Boolean   @default(false)
  scheduleId          String?
  categoryId          String?
  skillTreeId         String?
  nodeId              String?
  // JSON-stringified { intro, scalesExercises, topics, songWork, otherSongs, nextTime }.
  // When practiceNotesSentAt is null the sections are still a draft; once set they
  // represent the sent note. Kept alongside practiceNotes for back-compat.
  noteSections        String?
  // Snapshot of the student's routine as the coach set it at the end of this
  // session — same JSON shape as User.currentRoutine. Lets past sessions show
  // the routine that was current at that time and builds a routine history.
  routineSnapshot     String?
  createdAt           DateTime  @default(now())

  user           User               @relation(fields: [userId], references: [id])
  coach          User?              @relation("coachBookings", fields: [coachId], references: [id])
  lessonType     LessonType?        @relation(fields: [lessonTypeId], references: [id])
  category       Category?          @relation("bookingCategory", fields: [categoryId], references: [id])
  skillTree      SkillTree?         @relation("bookingSkillTree", fields: [skillTreeId], references: [id])
  node           SkillTreeNode?     @relation("bookingNode", fields: [nodeId], references: [id])
  lessonCategory LessonCategory?    @relation(fields: [lessonCategoryId], references: [id])
  schedule       RecurringSchedule? @relation(fields: [scheduleId], references: [id])
  messages       SessionMessage[]
  resources      SessionResource[]

  lessonSummary    LessonSummary?
  noteReadReceipts NoteReadReceipt[]
  noteVoiceMemos   NoteVoiceMemo[]
  assignments      Assignment[]
  googleEvents     GoogleEvent[]
}

model RecurringSchedule {
  id               String   @id @default(cuid())
  userId           String
  coachId          String
  lessonTypeId     String?
  lessonCategoryId String?
  dayOfWeek        Int
  startTime        String
  frequency        String   @default("WEEKLY")
  mode             String   @default("IN_PERSON")
  startsOn         DateTime
  endsOn           DateTime
  status           String   @default("ACTIVE")
  categoryId       String?
  skillTreeId      String?
  nodeId           String?
  createdAt        DateTime @default(now())

  user      User           @relation("studentSchedules", fields: [userId], references: [id])
  coach     User           @relation("coachSchedules", fields: [coachId], references: [id])
  category  Category?      @relation("scheduleCategory", fields: [categoryId], references: [id])
  skillTree SkillTree?     @relation("scheduleSkillTree", fields: [skillTreeId], references: [id])
  node      SkillTreeNode? @relation("scheduleNode", fields: [nodeId], references: [id])
  bookings  Booking[]
}

model SessionMessage {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  booking Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User                 @relation(fields: [senderId], references: [id])
  reads   SessionMessageRead[]
}

// Per-user read receipts on a SessionMessage. Combined with the
// User.lastInboxViewedAt timestamp this lets us support both "mark
// all read" (cheap bulk stamp) and per-item "mark read" toggles.
model SessionMessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message SessionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model SessionResource {
  id        String   @id @default(cuid())
  bookingId String
  addedById String
  type      String
  title     String
  url       String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addedBy User    @relation(fields: [addedById], references: [id])
}

// ─── Subscriptions ───

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  lessonsPerMonth Int
  priceMonthly    Int
  stripePriceId   String   @unique
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  subscriptions Subscription[]
}

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  planId                String
  stripeSubscriptionId  String   @unique
  status                String   @default("ACTIVE")
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  lessonsUsedThisPeriod Int      @default(0)
  createdAt             DateTime @default(now())

  user User             @relation(fields: [userId], references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
}

// ─── Workshops & Events ───

model Workshop {
  id            String   @id @default(cuid())
  title         String
  description   String
  lessonTypeId  String?
  dateTime      DateTime
  durationMins  Int
  maxCapacity   Int
  price         Int
  stripePriceId String?
  imageUrl      String?
  createdAt     DateTime @default(now())

  lessonType    LessonType?            @relation(fields: [lessonTypeId], references: [id])
  registrations WorkshopRegistration[]
}

model WorkshopRegistration {
  id              String   @id @default(cuid())
  workshopId      String
  userId          String
  stripePaymentId String?
  createdAt       DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id])

  @@unique([workshopId, userId])
}

model Event {
  id           String   @id @default(cuid())
  title        String
  description  String
  dateTime     DateTime
  durationMins Int
  imageUrl     String?
  createdAt    DateTime @default(now())

  rsvps EventRsvp[]
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?
  name      String
  email     String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@unique([eventId, email])
}

// ─── Community ───

model Song {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  audioUrl    String?
  externalUrl String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  likes    SongLike[]
  comments SongComment[]
}

model SongLike {
  id     String @id @default(cuid())
  songId String
  userId String

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([songId, userId])
}

model SongComment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

// ─── Contact ───

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ─── Practice / Coach UI ───

model PracticeStreak {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentDays     Int       @default(0)
  longestDays     Int       @default(0)
  lastPracticedAt DateTime?
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Per-week assignment of a warmup / exercise / song to a student.
model Assignment {
  id              String    @id @default(cuid())
  studentId       String
  coachId         String
  type            String    // "WARMUP" | "EXERCISE" | "SONG"
  title           String
  subtitle        String?
  bars            String?
  weekStartsOn    DateTime  // Monday of the week it applies to (UTC midnight)
  tempoBpmStart   Int?
  tempoBpmEnd     Int?
  durationMin     Int?
  status          String    @default("ASSIGNED")  // "ASSIGNED" | "IN_PROGRESS" | "COMPLETED"
  completionCount Int       @default(0)
  noteText        String?
  sortOrder       Int       @default(0)
  hasMidi         Boolean   @default(false)
  hasNotePinned   Boolean   @default(false)
  dueAt           DateTime?
  bookingId       String?
  resourceId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student User           @relation("studentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  coach   User           @relation("coachAssignments", fields: [coachId], references: [id])
  booking Booking?       @relation(fields: [bookingId], references: [id])
  resource CoachResource? @relation(fields: [resourceId], references: [id])
  takes   Take[]

  @@index([studentId, weekStartsOn])
}

// Audio submission from a student.
model Take {
  id          String    @id @default(cuid())
  studentId   String
  coachId     String
  assignmentId String?
  pieceTitle  String
  bars        String?
  takeNumber  Int       @default(1)
  durationSec Int
  audioUrl    String?
  selfRating  Int?      // 1-5
  selfNote    String?
  status      String    @default("UNREVIEWED")  // "UNREVIEWED" | "REVIEWING" | "REPLIED"
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  student     User        @relation("studentTakes", fields: [studentId], references: [id], onDelete: Cascade)
  coach       User        @relation("coachTakes", fields: [coachId], references: [id])
  assignment  Assignment? @relation(fields: [assignmentId], references: [id])
  annotations TakeAnnotation[]
  replies     TakeReply[]

  @@index([studentId, createdAt])
}

model TakeAnnotation {
  id             String    @id @default(cuid())
  takeId         String
  authorId       String
  kind           String    // "LOVE" | "WATCH" | "TRY_THIS"
  targetType     String    // "SCORE_BAR" | "TIMELINE"
  targetBar      Int?
  targetTimeSec  Float?
  text           String?
  voiceUrl       String?
  voiceDurSec    Int?
  createdAt      DateTime  @default(now())

  take   Take @relation(fields: [takeId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

model TakeReply {
  id          String   @id @default(cuid())
  takeId      String
  authorId    String
  text        String?
  voiceUrl    String?
  voiceDurSec Int?
  starRating  Int?
  summaryText String?
  createdAt   DateTime @default(now())

  take   Take @relation(fields: [takeId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

// Stubbed AI lesson summary: storage + manual edit; generation deferred.
model LessonSummary {
  id           String    @id @default(cuid())
  bookingId    String    @unique
  bullets      String    // JSON-stringified string[]
  status       String    @default("PENDING") // "PENDING" | "READY" | "EDITED"
  durationMin  Int?
  recordingUrl String?
  editedById   String?
  generatedAt  DateTime?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  editedBy User?   @relation("summaryEditor", fields: [editedById], references: [id])
}

model NoteReadReceipt {
  id        String   @id @default(cuid())
  bookingId String
  userId    String
  readAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([bookingId, userId])
}

model NoteVoiceMemo {
  id          String   @id @default(cuid())
  bookingId   String
  addedById   String
  audioUrl    String
  durationSec Int
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addedBy User    @relation(fields: [addedById], references: [id])
}

// One row per (student, routine item, day) the student checks off on their
// Practice path. routineItemId is the id of the item inside the User's
// currentRoutine JSON blob; `day` is UTC midnight so a completion is scoped
// to a calendar day. First completion of a day bumps PracticeStreak.
model RoutineCompletion {
  id            String   @id @default(cuid())
  userId        String
  routineItemId String
  day           DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, routineItemId, day])
  @@index([userId, day])
}

// Student-set practice goal, shared with their coach. A freshly-set goal
// (isNew) surfaces on the coach's session-prep agenda as a "talk through
// how to approach this" item; the coach clears isNew once it's discussed.
model Goal {
  id          String   @id @default(cuid())
  studentId   String
  coachId     String
  title       String
  detail      String?
  targetLabel String?  // free-text "by the June recital", "this month"…
  progressPct Int      @default(0) // 0-100
  status      String   @default("ACTIVE") // "ACTIVE" | "ACHIEVED" | "ARCHIVED"
  isNew       Boolean  @default(true)      // un-discussed → agenda item
  achievedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student User @relation("studentGoals", fields: [studentId], references: [id], onDelete: Cascade)
  coach   User @relation("coachGoals", fields: [coachId], references: [id])

  @@index([studentId, status])
  @@index([coachId, status])
}
