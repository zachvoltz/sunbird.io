generator client {
  provider = "prisma-client-js"
}

generator worker {
  provider = "prisma-client"
  output   = "../../../apps/api/src/generated/prisma"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String?
  avatarUrl      String?
  bio            String?
  role           String   @default("STUDENT")
  sessionAddress String?
  referralSource String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions        Session[]
  oauthAccounts   OAuthAccount[]
  subscription    Subscription?
  bookings        Booking[]
  songs           Song[]
  songLikes       SongLike[]
  songComments    SongComment[]
  eventRsvps      EventRsvp[]
  contactMessages    ContactMessage[]
  passwordResetTokens PasswordResetToken[]
  coachBookings      Booking[]           @relation("coachBookings")
  sentMessages       SessionMessage[]
  addedResources     SessionResource[]
  coachAvailability  CoachAvailability[]
  coachLessonTypes   CoachLessonType[]
  coachCurricula     Curriculum[]        @relation("coachCurricula")
  studentProgress    StudentProgress[]   @relation("studentProgress")
  coachProgressMarks StudentProgress[]   @relation("coachProgress")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id                   String    @id @default(cuid())
  provider             String
  providerId           String
  userId               String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  scopes               String?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Lessons & Scheduling ───

model LessonType {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  subtitle        String?
  description     String
  imageUrl        String?
  pricePerSession Int
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  categories      LessonCategory[]
  bookings        Booking[]
  workshops       Workshop[]
  coachLessonTypes CoachLessonType[]
  curricula        Curriculum[]
}

model LessonCategory {
  id           String  @id @default(cuid())
  lessonTypeId String
  slug         String
  title        String
  description  String?
  sortOrder    Int     @default(0)

  lessonType LessonType @relation(fields: [lessonTypeId], references: [id])
  bookings   Booking[]

  @@unique([lessonTypeId, slug])
}

model AvailabilitySlot {
  id        String  @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
}

model CoachAvailability {
  id        String  @id @default(cuid())
  coachId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)

  coach User @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([coachId, dayOfWeek, startTime])
}

model CoachLessonType {
  id           String @id @default(cuid())
  coachId      String
  lessonTypeId String

  coach      User       @relation(fields: [coachId], references: [id], onDelete: Cascade)
  lessonType LessonType @relation(fields: [lessonTypeId], references: [id], onDelete: Cascade)

  @@unique([coachId, lessonTypeId])
}

// ─── Curriculum / Skill Trees ───

model Curriculum {
  id           String   @id @default(cuid())
  coachId      String
  lessonTypeId String
  title        String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coach      User             @relation("coachCurricula", fields: [coachId], references: [id], onDelete: Cascade)
  lessonType LessonType       @relation(fields: [lessonTypeId], references: [id], onDelete: Cascade)
  nodes      CurriculumNode[]
  edges      CurriculumEdge[]

  @@unique([coachId, lessonTypeId])
}

model CurriculumNode {
  id           String  @id @default(cuid())
  curriculumId String
  title        String
  description  String?
  positionX    Float   @default(0)
  positionY    Float   @default(0)
  color        String?
  sortOrder    Int     @default(0)

  curriculum Curriculum        @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  edgesFrom  CurriculumEdge[]  @relation("edgeFrom")
  edgesTo    CurriculumEdge[]  @relation("edgeTo")
  progress   StudentProgress[]
  resources  NodeResource[]
  drills     PracticeDrill[]
}

model NodeResource {
  id        String   @id @default(cuid())
  nodeId    String
  type      String
  title     String
  url       String
  createdAt DateTime @default(now())

  node CurriculumNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model PracticeDrill {
  id          String  @id @default(cuid())
  nodeId      String
  title       String
  description String?
  resourceId  String?
  sortOrder   Int     @default(0)

  node CurriculumNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model CurriculumEdge {
  id           String @id @default(cuid())
  curriculumId String
  fromNodeId   String
  toNodeId     String

  curriculum Curriculum     @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  fromNode   CurriculumNode @relation("edgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     CurriculumNode @relation("edgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
}

model StudentProgress {
  id          String   @id @default(cuid())
  studentId   String
  nodeId      String
  coachId     String
  completedAt DateTime @default(now())
  notes       String?

  student User           @relation("studentProgress", fields: [studentId], references: [id], onDelete: Cascade)
  node    CurriculumNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  coach   User           @relation("coachProgress", fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([studentId, nodeId])
}

model Booking {
  id                  String    @id @default(cuid())
  userId              String
  coachId             String?
  lessonTypeId        String
  lessonCategoryId    String?
  startsAt            DateTime
  endsAt              DateTime
  status              String    @default("CONFIRMED")
  mode                String    @default("IN_PERSON")
  meetingUrl          String?
  meetingId           String?
  meetingProvider     String?
  studentNote         String?
  practiceNotes       String?
  practiceNotesSentAt DateTime?
  completedAt         DateTime?
  stripePaymentId     String?
  usedSubscription    Boolean   @default(false)
  createdAt           DateTime  @default(now())

  user           User            @relation(fields: [userId], references: [id])
  coach          User?           @relation("coachBookings", fields: [coachId], references: [id])
  lessonType     LessonType      @relation(fields: [lessonTypeId], references: [id])
  lessonCategory LessonCategory? @relation(fields: [lessonCategoryId], references: [id])
  messages       SessionMessage[]
  resources      SessionResource[]
}

model SessionMessage {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id])
}

model SessionResource {
  id        String   @id @default(cuid())
  bookingId String
  addedById String
  type      String
  title     String
  url       String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addedBy User    @relation(fields: [addedById], references: [id])
}

// ─── Subscriptions ───

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  lessonsPerMonth Int
  priceMonthly    Int
  stripePriceId   String   @unique
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  subscriptions Subscription[]
}

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  planId                String
  stripeSubscriptionId  String   @unique
  status                String   @default("ACTIVE")
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  lessonsUsedThisPeriod Int      @default(0)
  createdAt             DateTime @default(now())

  user User             @relation(fields: [userId], references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
}

// ─── Workshops & Events ───

model Workshop {
  id            String   @id @default(cuid())
  title         String
  description   String
  lessonTypeId  String?
  dateTime      DateTime
  durationMins  Int
  maxCapacity   Int
  price         Int
  stripePriceId String?
  imageUrl      String?
  createdAt     DateTime @default(now())

  lessonType    LessonType?            @relation(fields: [lessonTypeId], references: [id])
  registrations WorkshopRegistration[]
}

model WorkshopRegistration {
  id              String   @id @default(cuid())
  workshopId      String
  userId          String
  stripePaymentId String?
  createdAt       DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id])

  @@unique([workshopId, userId])
}

model Event {
  id           String   @id @default(cuid())
  title        String
  description  String
  dateTime     DateTime
  durationMins Int
  imageUrl     String?
  createdAt    DateTime @default(now())

  rsvps EventRsvp[]
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?
  name      String
  email     String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@unique([eventId, email])
}

// ─── Community ───

model Song {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  audioUrl    String?
  externalUrl String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  likes    SongLike[]
  comments SongComment[]
}

model SongLike {
  id     String @id @default(cuid())
  songId String
  userId String

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([songId, userId])
}

model SongComment {
  id        String   @id @default(cuid())
  songId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

// ─── Contact ───

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
